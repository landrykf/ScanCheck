, { useState } from 'react';\r\nimport axios from 'axios';\r\n  \r\n\r\nconst LoginForm = () => {\r\n    let [email, setEmail] = useState('');\r\n    let [password, setPassword] = useState('')\r\n\r\n\r\n    let handleLogin = (event) =>{\r\n        event.preventDefault();\r\n        let emailError = document.querySelector('.email.error');\r\n        let passwordError = document.querySelector('.password.error');\r\n\r\n\r\n        axios({\r\n            method: \"post\",\r\n            url:`${process.env.REACT_APP_API_URL}api/users/login/`,\r\n            whithCredentials: false,\r\n            data:{\r\n                email,\r\n                password,                \r\n            }\r\n        })\r\n        // console.log(axios1)\r\n        .then((res)=> {\r\n            console.log(res);\r\n            localStorage.setItem('token', res.data.token);\r\n            let header1=axios.defaults.headers.common['Authorization'] = 'Bearer ' + localStorage.getItem('token');\r\n            window.location = `/profil`\r\n            \r\n        })\r\n        .catch((err)=>{\r\n            // console.log(err.response.data.error)\r\n            // console.log(err.response)\r\n                if (err.response.data.error === \"mot de passe invalid\" ) {\r\n                    passwordError.innerHTML = err.response.data.error;\r\n                    \r\n                } else if (err.response.data.error === \"l'utlisateur n'existe pas dans la BDD\") {\r\n                    emailError.innerHTML = err.response.data.error;                  \r\n                } else{\r\n\r\n                    emailError.innerHTML = err.response.data.error;\r\n                    passwordError.innerHTML = err.response.data.error;\r\n                }\r\n            \r\n        })\r\n\r\n    }\r\n    return(\r\n        <form action=\"\" onSubmit={handleLogin} id= \"form-login\">\r\n            <label htmlFor=\"email\">Email</label>\r\n            <br/>\r\n            <input \r\n                type=\"text\" \r\n                name=\"email\" \r\n                id=\"email\" \r\n                onChange={(event) => setEmail(event.target.value)}\r\n                value={email}\r\n            />\r\n            <div className=\"email error\"></div>\r\n            \r\n            \r\n            <br/>\r\n            <label htmlFor=\"password\">Mot de passe</label>\r\n            <br/>\r\n            <input\r\n                type=\"password\"\r\n                name=\"password\"\r\n                id=\"password\"\r\n                onChange={(event) => setPassword(event.target.value)}\r\n                value={password}\r\n            />\r\n            <div className=\"password error\"></div>\r\n            <input type=\"submit\" value=\"Se connecter\"/>\r\n        </form>\r\n    )\r\n}\r\n\r\nexport default LoginForm;","C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\components\\Log\\RegisterForm.js",[],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\components\\AppContext.js",[],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\components\\Jikan\\Header.js",["77"],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\components\\jikan\\Header.js",["78","79","80"],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\components\\jikan\\Sidebar.js",["81"],"import React from 'react'\r\n\r\nfunction Sidebar({ topManga }) {\r\n    return (\r\n        \r\n            <aside>\r\n                <nav>\r\n                    <h3>Populaires</h3>\r\n                    {topManga.map(manga => (\r\n\r\n                    <a \r\n                        href='#'\r\n                        key = {manga.mal_id}\r\n                        rel=\"noreferrer\">\r\n                        \r\n                        {manga.title}\r\n                    </a>\r\n\r\n                    ))}\r\n\r\n                </nav>\r\n            </aside>\r\n        \r\n    )\r\n}\r\n\r\nexport default Sidebar\r\n","C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\components\\jikan\\HomeContent.js",[],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\components\\jikan\\MangaCard.js",["82","83"],"import React from 'react'\r\n\r\nfunction MangaCard({manga}) {\r\n    return (\r\n        <article className=\"manga-card\">\r\n            <a href='#' rel=\"noreferrer\">\r\n                <figure>\r\n                    <img\r\n                         src = {manga.image_url} \r\n                         alt = \"manga image\" />\r\n                </figure>\r\n                <h3>{manga.title}</h3>\r\n\r\n            </a>\r\n        </article>\r\n    )\r\n}\r\n\r\nexport default MangaCard\r\n","C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\components\\Navbar.js",["84","85","86"],{"ruleId":"87","severity":1,"message":"88","line":33,"column":6,"nodeType":"89","endLine":33,"endColumn":8,"suggestions":"90"},{"ruleId":"91","severity":1,"message":"92","line":13,"column":10,"nodeType":"93","messageId":"94","endLine":13,"endColumn":23},{"ruleId":"91","severity":1,"message":"95","line":39,"column":9,"nodeType":"93","messageId":"94","endLine":39,"endColumn":26},{"ruleId":"91","severity":1,"message":"96","line":40,"column":9,"nodeType":"93","messageId":"94","endLine":40,"endColumn":24},{"ruleId":"97","replacedBy":"98"},{"ruleId":"99","replacedBy":"100"},{"ruleId":"91","severity":1,"message":"101","line":29,"column":17,"nodeType":"93","messageId":"94","endLine":29,"endColumn":24},{"ruleId":"91","severity":1,"message":"102","line":1,"column":9,"nodeType":"93","messageId":"94","endLine":1,"endColumn":16},{"ruleId":"91","severity":1,"message":"103","line":4,"column":3,"nodeType":"93","messageId":"94","endLine":4,"endColumn":16},{"ruleId":"91","severity":1,"message":"104","line":5,"column":3,"nod