:0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"72"},{"filePath":"129","messages":"130","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"131","usedDeprecatedRules":"72"},{"filePath":"132","messages":"133","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"72"},{"filePath":"134","messages":"135","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"72"},{"filePath":"136","messages":"137","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"72"},{"filePath":"138","messages":"139","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"72"},{"filePath":"140","messages":"141","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"72"},{"filePath":"142","messages":"143","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"72"},{"filePath":"144","messages":"145","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"72"},"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\index.js",[],["146","147"],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\App.js",["148"],"import React from 'react';\r\nimport {useEffect, useState} from \"react\";\r\nimport Routes from \"./components/routes\";\r\nimport {UidContext} from \"./components/AppContext\"\r\nimport axios from \"axios\"\r\nimport { useDispatch } from \"react-redux\"\r\nimport { getUser } from './actions/user.actions';\r\n\r\n// part 2\r\nimport './styles/App.css'\r\nimport './lib/font-awesome/css/all.min.css'\r\n\r\nfunction App() {\r\n  const [uid, setUid] = useState(null);\r\n  const token = localStorage.getItem('token');\r\n  const dispatch = useDispatch();\r\n\r\n  useEffect(() => {\r\n    const fetchToken = async() => {\r\n      await axios({\r\n        method: \"get\",\r\n        url:`${process.env.REACT_APP_API_URL}api/users/me/`,\r\n        withCredentials: false,\r\n        headers: {\r\n          'Authorization': `Bearer ${token}`,\r\n        },  \r\n\r\n      })\r\n      .then((res) =>{\r\n        // console.log(res)\r\n        setUid(res.data)\r\n      })\r\n      .catch((err) =>{\r\n         console.log('no token '+ err)\r\n      })\r\n    };\r\n    fetchToken();\r\n\r\n    try {\r\n      \r\n      dispatch(getUser())      \r\n\r\n    } catch (err) {\r\n      console.log(err)\r\n    }\r\n\r\n \r\n  }, []);\r\n\r\n\r\n\r\n\r\n\r\n  return (\r\n    <div className=\"App\">\r\n      <UidContext.Provider value={uid}>\r\n      <header className=\"App-header\">\r\n\r\n        <h1> Ici mon app react </h1>\r\n        <Routes />\r\n\r\n      </header>\r\n      </UidContext.Provider>\r\n\r\n    </div>\r\n  );\r\n}\r\n\r\nexport default App;\r\n","C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\components\\routes\\index.js",[],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\pages\\Profil.js",[],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\pages\\Home.js",[],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\pages\\Trending.js",[],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\components\\Log\\index.js",[],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\components\\Log\\LoginForm.js",[],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\components\\Log\\RegisterForm.js",[],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\components\\AppContext.js",[],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\components\\Jikan\\Header.js",["149"],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\components\\jikan\\Header.js",[],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\components\\jikan\\Sidebar.js",["150"],"import React from 'react'\r\n\r\nfunction Sidebar({ topManga }) {\r\n    return (\r\n        \r\n            <aside>\r\n                <nav>\r\n                    <h3>Populaires</h3>\r\n                    {topManga.map(manga => (\r\n\r\n                    <a \r\n                        href='#'\r\n                        key = {manga.mal_id}\r\n                        rel=\"noreferrer\">\r\n                        \r\n                        {manga.title}\r\n                    </a>\r\n\r\n                    ))}\r\n\r\n                </nav>\r\n            </aside>\r\n        \r\n    )\r\n}\r\n\r\nexport default Sidebar\r\n","C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\components\\jikan\\HomeContent.js",[],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\components\\jikan\\MangaCard.js",["151"],"import React from \"react\";\r\nimport { NavLink } from \"react-router-dom\";\r\n\r\nfunction MangaCard({ manga }) {\r\n    // console.log(manga)\r\n  return (\r\n    <article className=\"manga-card\" onClick={manga.HandleDetail}>\r\n      <NavLink exact to=\"/detail\">\r\n          <figure>\r\n            <img src={manga.image_url} alt=\"manga image\" />\r\n          </figure>\r\n          <h3>{manga.title}</h3>\r\n\r\n      </NavLink>\r\n    </article>\r\n  );\r\n}\r\n\r\nexport default MangaCard;\r\n","C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\components\\Navbar.js",["152","153"],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\components\\Log\\Logout.js",[],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\reducers\\index.js",[],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\reducers\\user.reducer.js",[],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\actions\\user.actions.js",["154","155"],"import axios from \"axios\";\r\nimport { useEffect, useState } from \"react\";\r\n\r\nexport const GET_USER = \"GET_USER\";\r\nexport const UPDATE_BIO = \"UPDATE_BIO\";\r\nexport const UPDATE_INFO = \"UPDATE_INFO\"\r\n\r\nexport const getUser = () => {\r\n  const token = localStorage.getItem(\"token\");\r\n\r\n  \r\n  return async (dispatch) => {\r\n    await axios({\r\n      method: \"get\",\r\n      url: `${process.env.REACT_APP_API_URL}api/users/me/`,\r\n      withCredentials: false,\r\n      headers: {\r\n        Authorization: `Bearer ${token}`,\r\n      },\r\n    })\r\n      .then((res) => {\r\n        // console.log(res);\r\n        dispatch({ type: GET_USER, payload: res.data });\r\n      })\r\n      .catch((err) => {\r\n        console.log(err);\r\n\r\n      });\r\n  };\r\n};\r\n\r\nexport const updateBio = (id ,bio) => {\r\n  const token = localStorage.getItem('token');\r\n\r\n    return (dispatch) => {\r\n        return axios({\r\n            method: \"put\",\r\n            url:`${process.env.REACT_APP_API_URL}api/users/me/`,\r\n            whithCredentials: false,\r\n            headers: {\r\n                'Authorization': `Bearer ${token}`,\r\n              },  \r\n            data:{bio},\r\n        })\r\n        .then((res)=>{\r\n            // console.log(res)\r\n            dispatch({type: UPDATE_BIO, payload: bio})\r\n        })\r\n        .catch((err)=>console.log(err))\r\n    }\r\n}\r\n\r\nexport const updateInfo = (username,email) => {\r\n    const token = localStorage.getItem('token');\r\n    console.log({username})\r\n\r\n    return(dispatch) => {\r\n        return axios({\r\n            method: \"put\",\r\n            url:`${process.env.REACT_APP_API_URL}api/users/me/`,\r\n            whithCredentials: false,\r\n            headers: {\r\n                'Authorization': `Bearer ${token}`,\r\n              },  \r\n            data :{\r\n                username,\r\n                email\r\n            }\r\n        })\r\n        .then((res)=>{\r\n            console.log(res)\r\n            dispatch({type: UPDATE_INFO, payload:{username,email}})\r\n        })\r\n    }\r\n}\r\n","C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\pages\\Account.js",["156"],"import React from 'react';\r\nimport { Uid } from \"../components/AppContext\";\r\nimport UpdateProfil from \"../components/Setting/UpdateProfil\";\r\nimport Navbar from \"../components/Navbar\"\r\nfunction Account() {\r\n    return (\r\n        <div>\r\n            <Navbar/>\r\n            <UpdateProfil/>\r\n        </div>\r\n    )\r\n}\r\n\r\nexport default Account\r\n","C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\components\\Setting\\UpdateProfil.js",["157","158","159","160"],"import React from \"react\";\r\nimport { useSelector, useDispatch } from \"react-redux\";\r\nimport { useEffect, useState } from \"react\";\r\nimport { updateBio, updateInfo } from \"../../actions/user.actions\";\r\n\r\nfunction UpdateProfil() {\r\n  const [bio, setBio] = useState(\"\");\r\n  const [password, setPassword] = useState(\"\");\r\n  const [username, setUsername] = useState(\"\");\r\n  const [email, setEmail] = useState(\"\");\r\n\r\n  const [updateForm, setUpdateForm] = useState(true);\r\n\r\n  const userData = useSelector((state) => state.userReducer);\r\n//   console.log(userData);\r\n  const dispatch = useDispatch();\r\n\r\n  const handleUpdate = (event) => {\r\n    event.preventDefault();\r\n    dispatch(updateBio(userData.user.id, bio));\r\n    setUpdateForm(false);\r\n    let sUsername = username;\r\n\r\n    if(sUsername == null){\r\n        sUsername = userData.user.username;\r\n    }\r\n    if (email == null) {\r\n        setEmail(userData.user.email);\r\n    }\r\n    \r\n    dispatch(updateInfo(sUsername,email))\r\n\r\n\r\n  };\r\n\r\nconst test = (username)=>{\r\n    console.log({username});\r\n}  \r\n\r\n  return (\r\n    <div className=\"setting-page\">\r\n      <h2>Login</h2>\r\n      <div className=\"img-part\">\r\n        <img\r\n          src=\"https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcQpHD3N92mlHfopLSOZZpvyXGpcO19FdenrLA&usqp=CAU\"\r\n          alt=\"user pic\"\r\n        />\r\n        <h4>Votre pseudo : {userData?.user?.username}</h4>\r\n      </div>\r\n      <div className=\"info-part\">\r\n\r\n        <h2>Informations</h2>\r\n        <div className=\"bio-update\">\r\n          <h5> Bio </h5>\r\n          {updateForm === false && (\r\n            <>\r\n              <p onClick={() => setUpdateForm(!updateForm)}>\r\n                {userData?.user?.bio}\r\n              </p>\r\n              <button onClick={() => setUpdateForm(!updateForm)}>\r\n                Modifier bio\r\n              </button>\r\n            </>\r\n          )}\r\n          {updateForm && (\r\n            <>\r\n              <textarea\r\n                type=\"text\"\r\n                defaultValue={userData?.user?.bio}\r\n                onChange={(event) => setBio(event.target.value)}\r\n              ></textarea>\r\n              <button onClick={handleUpdate}>Valider changement</button>\r\n            </>\r\n          )}\r\n        </div>\r\n\r\n        <form action=\"\" onSubmit={handleUpdate} id=\"form-update\">\r\n          <div className=\"username-update\">\r\n\r\n\r\n            <label htmlFor=\"username\">Pseudo: </label>\r\n\r\n            <input\r\n              type=\"text\"\r\n              defaultValue={userData?.user?.username}\r\n              onChange={(event) => setUsername(event.target.value)}\r\n            />\r\n   \r\n            <br/>    \r\n            <label htmlFor=\"email\">Email: </label>\r\n\r\n            <input\r\n            type=\"text\"\r\n            defaultValue={userData?.user?.email}\r\n            onChange={(event) => setEmail(event.target.value)}\r\n            />\r\n            <br />\r\n            \r\n            <input type=\"submit\" value=\"Valider\" />\r\n          </div>\r\n        </form>\r\n      </div>\r\n    </div>\r\n  );\r\n}\r\n\r\nexport default UpdateProfil;\r\n","C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\pages\\Watchlist.js",["161","162","163","164","165","166"],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\components\\jikan\\MangaDetail.js",["167","168"],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\reportWebVitals.js",[],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\context\\GlobalState.js",[],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\context\\AppReducer.js",["169"],"export default (state, action) => {\r\n  switch (action.type) {\r\n    case \"ADD_MANGA_TO_READLIST\":\r\n      //   console.log(state);\r\n      return {\r\n        ...state,\r\n        readlist: [action.payload, ...state.readlist],\r\n      };\r\n\r\n    case \"REMOVE_MOVIE_FROM_WATCHLIST\":\r\n      // console.log(action);\r\n      return {\r\n        ...state,\r\n        readlist: state.readlist.filter(\r\n          (manga) => manga.mal_id !== action.payload\r\n        ),\r\n      };\r\n\r\n    case \"ADD_MANGA_TO_READED\":\r\n      console.log(action.payload);\r\n      return {\r\n        ...state,\r\n        readlist: state.readlist.filter(\r\n          (manga) => manga.mal_id !== action.payload.mal_id\r\n        ),\r\n        readed: [action.payload, ...state.readed],\r\n      };\r\n\r\n    case \"MOVE_TO_READLIST\":\r\n      return {\r\n        ...state,\r\n        readed: state.readed.filter(\r\n          (manga) => manga.mal_id !== action.payload.mal_id,\r\n          ),\r\n          readlist : [action.payload, ...state.readlist]\r\n      };\r\n\r\n      case \"REMOVE_FROM_WATCHED\":\r\n          return{\r\n              ...state,\r\n              readed: state.readed.filter(\r\n                  (manga) => manga.mal_id !== action.payload\r\n              )\r\n          }\r\n\r\n    default:\r\n      return state;\r\n  }\r\n};\r\n","C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\components\\Mangalist\\Header.js",[],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\components\\Mangalist\\Readed.js",[],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\components\\Mangalist\\Readlist.js",[],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\components\\Mangalist\\MangaCard.js",[],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\components\\Mangalist\\MangaControls.js",[],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\components\\Mangalist\\Add.js",[],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\components\\Mangalist\\ResultCard.js",[],{"ruleId":"170","replacedBy":"171"},{"ruleId":"172","replacedBy":"173"},{"ruleId":"174","severity":1,"message":"175","line":48,"column":6,"nodeType":"176","endLine":48,"endColumn":8,"suggestions":"177"},{"ruleId":"178","severity":1,"message":"179","line":1,"column":9,"nodeType":"180","messageId":"181","endLine":1,"endColumn":16},{"ruleId":"182","severity":1,"message":"183","line":11,"column":21,"nodeType":"184","endLine":14,"endColumn":42},{"ruleId":"185","severity":1,"message":"186","line":10,"column":13,"nodeType":"184","endLine":10,"endColumn":60},{"ruleId":"178","severity":1,"message":"187","line":11,"column":9,"nodeType":"180","messageId":"181","endLine":11,"endColumn":12},{"ruleId":"178","severity":1,"message":"188","line":22,"column":9,"nodeType":"180","messageId":"181","endL