arningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"73"},{"filePath":"131","messages":"132","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"73"},{"filePath":"133","messages":"134","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"73"},{"filePath":"135","messages":"136","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"73"},{"filePath":"137","messages":"138","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"139","usedDeprecatedRules":"73"},{"filePath":"140","messages":"141","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"73"},{"filePath":"142","messages":"143","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"73"},"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\index.js",[],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\App.js",["144"],"import React from 'react';\r\nimport {useEffect, useState} from \"react\";\r\nimport Routes from \"./components/routes\";\r\nimport {UidContext} from \"./components/AppContext\"\r\nimport axios from \"axios\"\r\nimport { useDispatch } from \"react-redux\"\r\nimport { getUser } from './actions/user.actions';\r\n\r\n// part 2\r\nimport './styles/App.css'\r\nimport './lib/font-awesome/css/all.min.css'\r\n\r\nfunction App() {\r\n  const [uid, setUid] = useState(null);\r\n  const token = localStorage.getItem('token');\r\n  const dispatch = useDispatch();\r\n\r\n  useEffect(() => {\r\n    const fetchToken = async() => {\r\n      await axios({\r\n        method: \"get\",\r\n        url:`${process.env.REACT_APP_API_URL}api/users/me/`,\r\n        withCredentials: false,\r\n        headers: {\r\n          'Authorization': `Bearer ${token}`,\r\n        },  \r\n\r\n      })\r\n      .then((res) =>{\r\n        // console.log(res)\r\n        setUid(res.data)\r\n      })\r\n      .catch((err) =>{\r\n         console.log('no token '+ err)\r\n      })\r\n    };\r\n    fetchToken();\r\n\r\n    try {\r\n      \r\n      dispatch(getUser())      \r\n\r\n    } catch (err) {\r\n      console.log(err)\r\n    }\r\n\r\n \r\n  }, []);\r\n\r\n\r\n\r\n\r\n\r\n  return (\r\n    <div className=\"App\">\r\n      <UidContext.Provider value={uid}>\r\n      <header className=\"App-header\">\r\n\r\n        <h1> Ici mon app react </h1>\r\n        <Routes />\r\n\r\n      </header>\r\n      </UidContext.Provider>\r\n\r\n    </div>\r\n  );\r\n}\r\n\r\nexport default App;\r\n",["145","146"],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\components\\routes\\index.js",[],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\pages\\Profil.js",[],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\pages\\Home.js",[],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\pages\\Trending.js",[],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\components\\Log\\index.js",[],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\components\\Log\\LoginForm.js",[],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\components\\Log\\RegisterForm.js",[],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\components\\AppContext.js",[],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\components\\Jikan\\Header.js",["147"],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\components\\jikan\\Header.js",[],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\components\\jikan\\Sidebar.js",["148"],"import React from 'react'\r\n\r\nfunction Sidebar({ topManga }) {\r\n    return (\r\n        \r\n            <aside>\r\n                <nav>\r\n                    <h3>Populaires</h3>\r\n                    {topManga.map(manga => (\r\n\r\n                    <a \r\n                        href='#'\r\n                        key = {manga.mal_id}\r\n                        rel=\"noreferrer\">\r\n                        \r\n                        {manga.title}\r\n                    </a>\r\n\r\n                    ))}\r\n\r\n                </nav>\r\n            </aside>\r\n        \r\n    )\r\n}\r\n\r\nexport default Sidebar\r\n","C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\components\\jikan\\HomeContent.js",[],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\components\\jikan\\MangaCard.js",["149"],"import React from \"react\";\r\nimport { NavLink } from \"react-router-dom\";\r\n\r\nfunction MangaCard({ manga }) {\r\n    // console.log(manga)\r\n  return (\r\n    <article className=\"manga-card\" onClick={manga.HandleDetail}>\r\n      <NavLink exact to=\"/detail\">\r\n          <figure>\r\n            <img src={manga.image_url} alt=\"manga image\" />\r\n          </figure>\r\n          <h3>{manga.title}</h3>\r\n\r\n      </NavLink>\r\n    </article>\r\n  );\r\n}\r\n\r\nexport default MangaCard;\r\n","C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\components\\Navbar.js",["150","151"],"import React from \"react\";\r\nimport { useContext } from \"react\";\r\nimport { NavLink } from \"react-router-dom\";\r\nimport { UidContext } from \"./AppContext\";\r\nimport Logout from \"./Log/Logout\";\r\nimport { FontAwesomeIcon } from \"@fortawesome/react-fontawesome\";\r\nimport { useSelector } from \"react-redux\";\r\n\r\n// import {\r\n//   faCheckSquare,\r\n//   faCoffee,\r\n//   faSignInAlt,\r\n// } from \"@fortawesome/fontawesome-free-solid\";\r\n\r\nfunction Navbar() {\r\n  const uid = useContext(UidContext);\r\n  const userData = useSelector((state) => state.userReducer);\r\n  // console.log(uid);\r\n\r\n  return (\r\n    <div className=\"nav-container\">\r\n      <div>\r\n        <div className=\"logo\">\r\n          <NavLink exact to=\"/\">\r\n            <img src=\"./img/logo.png\" alt=\"logo\" width=\"100\" />\r\n            <span>Scancheck</span>\r\n          </NavLink>\r\n        </div>\r\n\r\n        <div className=\"icons\">\r\n          <div className=\"icons-bis\">\r\n            <NavLink to=\"/profil\" exact activeClassName=\"active-icon-nav\">\r\n              <span>\r\n                <FontAwesomeIcon icon={\"user-circle\"} /> profil\r\n              </span>\r\n            </NavLink>\r\n            <br />\r\n            <NavLink to=\"/account\" exact activeClassName=\"active-icon-nav\">\r\n              <span>\r\n                <FontAwesomeIcon icon={\"user-cog\"} /> reglages\r\n              </span>\r\n            </NavLink>\r\n            <br />\r\n            <NavLink to=\"/explore\" exact activeClassName=\"active-icon-nav\">\r\n              <span>\r\n                <FontAwesomeIcon icon={\"compass\"} /> explorer\r\n              </span>\r\n            </NavLink>\r\n\r\n            <h5>{\" \" + uid?.user?.username}</h5>\r\n\r\n            <ul>\r\n              <li className=\"welcome\">\r\n                <NavLink exact to=\"/\">\r\n                  <Logout />\r\n                </NavLink>\r\n              </li>\r\n            </ul>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  );\r\n}\r\n\r\nexport default Navbar;\r\n","C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\components\\Log\\Logout.js",[],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\reducers\\index.js",[],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\reducers\\user.reducer.js",[],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\actions\\user.actions.js",["152","153"],"import axios from \"axios\";\r\nimport { useEffect, useState } from \"react\";\r\n\r\nexport const GET_USER = \"GET_USER\";\r\nexport const UPDATE_BIO = \"UPDATE_BIO\";\r\nexport const UPDATE_INFO = \"UPDATE_INFO\"\r\n\r\nexport const getUser = () => {\r\n  const token = localStorage.getItem(\"token\");\r\n\r\n  \r\n  return async (dispatch) => {\r\n    await axios({\r\n      method: \"get\",\r\n      url: `${process.env.REACT_APP_API_URL}api/users/me/`,\r\n      withCredentials: false,\r\n      headers: {\r\n        Authorization: `Bearer ${token}`,\r\n      },\r\n    })\r\n      .then((res) => {\r\n        // console.log(res);\r\n        dispatch({ type: GET_USER, payload: res.data });\r\n      })\r\n      .catch((err) => {\r\n        console.log(err);\r\n\r\n      });\r\n  };\r\n};\r\n\r\nexport const updateBio = (id ,bio) => {\r\n  const token = localStorage.getItem('token');\r\n\r\n    return (dispatch) => {\r\n        return axios({\r\n            method: \"put\",\r\n            url:`${process.env.REACT_APP_API_URL}api/users/me/`,\r\n            whithCredentials: false,\r\n            headers: {\r\n                'Authorization': `Bearer ${token}`,\r\n              },  \r\n            data:{bio},\r\n        })\r\n        .then((res)=>{\r\n            // console.log(res)\r\n            dispatch({type: UPDATE_BIO, payload: bio})\r\n        })\r\n        .catch((err)=>console.log(err))\r\n    }\r\n}\r\n\r\nexport const updateInfo = (username,email) => {\r\n    const token = localStorage.getItem('token');\r\n    console.log({username})\r\n\r\n    return(dispatch) => {\r\n        return axios({\r\n            method: \"put\",\r\n            url:`${process.env.REACT_APP_API_URL}api/users/me/`,\r\n            whithCredentials: false,\r\n            headers: {\r\n                'Authorization': `Bearer ${token}`,\r\n              },  \r\n            data :{\r\n                username,\r\n                email\r\n            }\r\n        })\r\n        .then((res)=>{\r\n            console.log(res)\r\n            dispatch({type: UPDATE_INFO, payload:{username,email}})\r\n        })\r\n    }\r\n}\r\n","C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\pages\\Account.js",["154"],"import React from 'react';\r\nimport { Uid } from \"../components/AppContext\";\r\nimport UpdateProfil from \"../components/Setting/UpdateProfil\";\r\nimport Navbar from \"../components/Navbar\"\r\nfunction Account() {\r\n    return (\r\n        <div>\r\n            <Navbar/>\r\n            <UpdateProfil/>\r\n        </div>\r\n    )\r\n}\r\n\r\nexport default Account\r\n","C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\components\\Setting\\UpdateProfil.js",["155","156","157","158"],"import React from \"react\";\r\nimport { useSelector, useDispatch } from \"react-redux\";\r\nimport { useEffect, useState } from \"react\";\r\nimport { updateBio, updateInfo } from \"../../actions/user.actions\";\r\n\r\nfunction UpdateProfil() {\r\n  const [bio, setBio] = useState(\"\");\r\n  const [password, setPassword] = useState(\"\");\r\n  const [username, setUsername] = useState(\"\");\r\n  const [email, setEmail] = useState(\"\");\r\n\r\n  const [updateForm, setUpdateForm] = useState(true);\r\n\r\n  const userData = useSelector((state) => state.userReducer);\r\n//   console.log(userData);\r\n  const dispatch = useDispatch();\r\n\r\n  const handleUpdate = (event) => {\r\n    event.preventDefault();\r\n    dispatch(updateBio(userData.user.id, bio));\r\n    setUpdateForm(false);\r\n    let sUsername = username;\r\n\r\n    if(sUsername == null){\r\n        sUsername = userData.user.username;\r\n    }\r\n    if (email == null) {\r\n        setEmail(userData.user.email);\r\n    }\r\n    \r\n    dispatch(updateInfo(sUsername,email))\r\n\r\n\r\n  };\r\n\r\nconst test = (username)=>{\r\n    console.log({username});\r\n}  \r\n\r\n  return (\r\n    <div className=\"setting-page\">\r\n      <h2>Login</h2>\r\n      <div className=\"img-part\">\r\n        <img\r\n          src=\"https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcQpHD3N92mlHfopLSOZZpvyXGpcO19FdenrLA&usqp=CAU\"\r\n          alt=\"user pic\"\r\n        />\r\n        <h4>Votre pseudo : {userData?.user?.username}</h4>\r\n      </div>\r\n      <div className=\"info-part\">\r\n\r\n        <h2>Informations</h2>\r\n        <div className=\"bio-update\">\r\n          <h5> Bio </h5>\r\n          {updateForm === false && (\r\n            <>\r\n              <p onClick={() => setUpdateForm(!updateForm)}>\r\n                {userData?.user?.bio}\r\n              </p>\r\n              <button onClick={() => setUpdateForm(!updateForm)}>\r\n                Modifier bio\r\n              </button>\r\n            </>\r\n          )}\r\n          {updateForm && (\r\n            <>\r\n              <textarea\r\n                type=\"text\"\r\n                defaultValue={userData?.user?.bio}\r\n                onChange={(event) => setBio(event.target.value)}\r\n              ></textarea>\r\n              <button onClick={handleUpdate}>Valider changement</button>\r\n            </>\r\n          )}\r\n        </div>\r\n\r\n        <form action=\"\" onSubmit={handleUpdate} id=\"form-update\">\r\n          <div className=\"username-update\">\r\n\r\n\r\n            <label htmlFor=\"username\">Pseudo: </label>\r\n\r\n            <input\r\n              type=\"text\"\r\n              defaultValue={userData?.user?.username}\r\n              onChange={(event) => setUsername(event.target.value)}\r\n            />\r\n   \r\n            <br/>    \r\n            <label htmlFor=\"email\">Email: </label>\r\n\r\n            <input\r\n            type=\"text\"\r\n            defaultValue={userData?.user?.email}\r\n            onChange={(event) => setEmail(event.target.value)}\r\n            />\r\n            <br />\r\n            \r\n            <input type=\"submit\" value=\"Valider\" />\r\n          </div>\r\n        </form>\r\n      </div>\r\n    </div>\r\n  );\r\n}\r\n\r\nexport default UpdateProfil;\r\n","C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\reportWebVitals.js",[],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\pages\\Watchlist.js",["159","160","161","162","163","164"],"import React from \"react\";\r\nimport { useState, useEffect } from \"react\";\r\n\r\nimport HomeContent from \"../components/jikan/HomeContent\";\r\nimport Navbar from \"../components/Navbar\";\r\n\r\n//part 2\r\n\r\nimport { Header } from \"../components/Mangalist/Header\";\r\nimport { Readlist } from \"../components/Mangalist/Readlist\";\r\nimport { Readed } from \"../components/Mangalist/Readed\";\r\nimport { Add } from \"../components/Mangalist/Add\"\r\n\r\nconst Watchlist = () => {\r\n  const [mangaList, SetMangaList] = useState([]);\r\n  const [search, SetSearch] = useState(\"\");\r\n\r\n  const HandleSearch = (event) => {\r\n    event.preventDefault();\r\n    FetchManga(search);\r\n  };\r\n\r\n  const FetchManga = async (query) => {\r\n    const searchReq = await fetch(\r\n      `https://api.jikan.moe/v3/search/manga?q=${query}&order_by=title&sort=asc&limit=20`\r\n    ).then((res) => res.json());\r\n\r\n    SetMangaList(searchReq.results);\r\n  };\r\n\r\n  return (\r\n    <div className=\"watchlist-page\">\r\n      <div>\r\n        <div>\r\n          <Navbar />\r\n          <h2>UPDATE PAGE</h2>\r\n        </div>\r\n        <Add/>\r\n        {/* <Header /> */}\r\n        <Readlist />\r\n        <Readed />\r\n\r\n        {/* <HomeContent\r\n          HandleSearch={HandleSearch}\r\n          search={search}\r\n          SetSearch={SetSearch}\r\n          mangaList={mangaList}\r\n        /> */}\r\n      </div>\r\n    </div>\r\n  );\r\n};\r\n\r\nexport default Watchlist;\r\n","C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\context\\GlobalState.js",[],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\components\\Mangalist\\Add.js",[],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\components\\Mangalist\\Header.js",[],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\components\\Mangalist\\Readlist.js",[],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\components\\Mangalist\\Readed.js",[],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\components\\Mangalist\\ResultCard.js",[],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\context\\AppReducer.js",["165"],"export default (state, action) => {\r\n  switch (action.type) {\r\n    case \"ADD_MANGA_TO_READLIST\":\r\n      //   console.log(state);\r\n      return {\r\n        ...state,\r\n        readlist: [action.payload, ...state.readlist],\r\n      };\r\n\r\n    case \"REMOVE_MOVIE_FROM_WATCHLIST\":\r\n      // console.log(action);\r\n      return {\r\n        ...state,\r\n        readlist: state.readlist.filter(\r\n          (manga) => manga.mal_id !== action.payload\r\n        ),\r\n      };\r\n\r\n    case \"ADD_MANGA_TO_READED\":\r\n      console.log(action.payload);\r\n      return {\r\n        ...state,\r\n        readlist: state.readlist.filter(\r\n          (manga) => manga.mal_id !== action.payload.mal_id\r\n        ),\r\n        readed: [action.payload, ...state.readed],\r\n      };\r\n\r\n    case \"MOVE_TO_READLIST\":\r\n      return {\r\n        ...state,\r\n        readed: state.readed.filter(\r\n          (manga) => manga.mal_id !== action.payload.mal_id,\r\n          ),\r\n          readlist : [action.payload, ...state.readlist]\r\n      };\r\n\r\n      case \"REMOVE_FROM_WATCHED\":\r\n          return{\r\n              ...state,\r\n              readed: state.readed.filter(\r\n                  (manga) => manga.mal_id !== action.payload\r\n              )\r\n          }\r\n\r\n    default:\r\n      return state;\r\n  }\r\n};\r\n","C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\components\\Mangalist\\MangaCard.js",[],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\components\\Mangalist\\MangaControls.js",[],{"ruleId":"166","severity":1,"message":"167","line":48,"column":6,"nodeType":"168","endLine":48,"endColumn":8,"suggestions":"169"},{"ruleId":"170","replacedBy":"171"},{"ruleId":"172","replacedBy":"173"},{"ruleId":"174","severity":1,"message":"175","line":1,"column":9,"nodeType":"176","messageId":"177","endLine":1,"endColumn":16},{"ruleId":"178","severity":1,"message":"179","line":11,"column":21,"nodeType":"180","endLine":14,"endColumn":42},{"ruleId":"181","severity":1,"message":"182","line":10,"column":13,"nodeType":"180","endLine":10,"endColumn":60},{"ruleId":"174","severity":1,"message":"183","line":11,"column":9,"nodeType":"176","messageId":"177","endLine":11,"endColumn":12},{"ruleId":"174","severity":1,"message":"184","line":22,"column":9,"nodeType":"176","messageId":"177","endLine":22,"endColumn":17},{"ruleId":"174","severity":1,"message":"185","line":2,"column":10,"nodeType":"176","messageId":"177","endLine":2,"endColumn":19},{"ruleId":"174","severity":1,"message":"186","line":2,"column":21,"nodeType":"176","messageId":"177","endLine":2,"endColumn":29},{"ruleId":"174","severity":1,"message":"187","line":2,"column":10,"nodeType":"176","messageId":"177","endLine":2,"endColumn":13},{"ruleId":"174","severity":1,"message":"185","line":3,"column":10,"nodeType":"176","messageId":"177","endLine":3,"endColumn":19},{"ruleId":"174","severity":1,"message":"188","line":8,"column":10,"nodeType":"176","messageId":"177","endLine":8,"endColumn":18},{"ruleId":"174","severity":1,"message":"189","line":8,"column":20,"nodeType":"176","messageId":"177","endLine":8,"endColumn":31},{"ruleId":"174","severity":1,"message":"190","line":36,"column":7,"nodeType":"176","messageId":"177","endLine":36,"endColumn":11},{"ruleId":"174","severity":1,"message":"185","line":2,"column":20,"nodeType":"176","messageId":"177","endLine":2,"endColumn":29},{"ruleId":"174","severity":1,"message":"191","line":4,"column":8,"nodeType":"176","messageId":"177","endLine":4,"endColumn":19},{"ruleId":"174","severity":1,"message":"192","line":9,"column":10,"nodeType":"176","messageId":"177","endLine":9,"endColumn":16},{"ruleId":"174","severity":1,"message":"193","line":15,"column":10,"nodeType":"176","messageId":"177","endLine":15,"endColumn":19},{"ruleId":"174","severity":1,"message":"194","line":16,"column":18,"nodeType":"176","messageId":"177","endLine":16,"endColumn":27},{"ruleId":"174","severity":1,"message":"195","line":18,"column":9,"nodeType":"176","messageId":"177","endLine":18,"endColumn":21},{"ruleId":"196","severity":1,"message":"197","line":1,"column":1,"nodeType":"198","endLine":49,"endColumn":3},"react-hooks/exhaustive-deps","React Hook useEffect has missing dependencies: 'dispatch' and 'token'. Either include them or remove the dependency array.","ArrayExpression",["199"],"no-native-reassign",["200"],"no-negated-in-lhs",["201"],"no-unused-vars","'reflect' is assigned a value but never used.","Identifier","unusedVar","jsx-a11y/anchor-is-valid","The href attribute requires a valid value to be accessible. Provide a valid, navigable address as the href value. If you cannot provide a valid href, but still need the element to resemble a link, use a button and change it with appropriate styles. Learn more: https://github.com/evcohen/eslint-plugin-jsx-a11y/blob/master/docs/rules/anchor-is-valid.md","JSXOpeningElement","jsx-a11y/img-redundant-alt","Redundant alt attribute. Screen-readers already announce `img` tags as an image. You don’t need to use the words `image`, `photo,` or `picture` (or any specified custom words) in the alt prop.","'Add' is defined but never used.","'userData' is assigned a value but never used.","'useEffect' is defined but never used.","'useState' is defined but never used.","'Uid' is defined but never used.","'password' is assigned a value but never used.","'setPassword' is assigned a value but never used.","'test' is assigned a value but never used.","'HomeContent' is defined but never used.","'Header' is defined but never used.","'mangaList' is assigned a value but never used.","'SetSearch' is assigned a value but never used.","'HandleSearch' is assigned a value but never used.","import/no-anonymous-default-export","Assign arrow function to a variable before exporting as module default","ExportDefaultDeclaration",{"desc":"202","fix":"203"},"no-global-assign","no-unsafe-negation","Update the dependencies array to be: [dispatch, token]",{"range":"204","text":"205"},[1117,1119],"[dispatch, token]"]