bleWarningCount":0,"usedDeprecatedRules":"51"},{"filePath":"77","messages":"78","errorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":"79","usedDeprecatedRules":"51"},{"filePath":"80","messages":"81","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"82","usedDeprecatedRules":"51"},{"filePath":"83","messages":"84","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"51"},{"filePath":"85","messages":"86","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"51"},{"filePath":"87","messages":"88","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"51"},{"filePath":"89","messages":"90","errorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":"91","usedDeprecatedRules":"51"},{"filePath":"92","messages":"93","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"94","usedDeprecatedRules":"51"},{"filePath":"95","messages":"96","errorCount":0,"warningCount":4,"fixableErrorCount":0,"fixableWarningCount":0,"source":null},"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\index.js",[],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\App.js",["97"],"import React from 'react';\r\nimport {useEffect, useState} from \"react\"\r\nimport Routes from \"./components/routes\";\r\nimport {UidContext} from \"./components/AppContext\"\r\nimport axios from \"axios\"\r\nimport { useDispatch } from \"react-redux\"\r\nimport { getUser } from './actions/user.actions';\r\n\r\nfunction App() {\r\n  const [uid, setUid] = useState(null);\r\n  const token = localStorage.getItem('token');\r\n  const dispatch = useDispatch();\r\n\r\n  useEffect(() => {\r\n    const fetchToken = async() => {\r\n      await axios({\r\n        method: \"get\",\r\n        url:`${process.env.REACT_APP_API_URL}api/users/me/`,\r\n        withCredentials: false,\r\n        headers: {\r\n          'Authorization': `Bearer ${token}`,\r\n        },  \r\n\r\n      })\r\n      .then((res) =>{\r\n        // console.log(res)\r\n        setUid(res.data)\r\n      })\r\n      .catch((err) =>{\r\n         console.log('no token '+ err)\r\n      })\r\n    };\r\n    fetchToken();\r\n\r\n    try {\r\n      \r\n      dispatch(getUser())      \r\n\r\n    } catch (err) {\r\n      console.log(err)\r\n    }\r\n\r\n \r\n  }, []);\r\n\r\n\r\n\r\n\r\n\r\n  return (\r\n    <div className=\"App\">\r\n      <UidContext.Provider value={uid}>\r\n      <header className=\"App-header\">\r\n\r\n        <h1> Ici mon app react </h1>\r\n        <Routes />\r\n\r\n      </header>\r\n      </UidContext.Provider>\r\n\r\n    </div>\r\n  );\r\n}\r\n\r\nexport default App;\r\n",["98","99"],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\components\\routes\\index.js",[],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\pages\\Profil.js",[],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\pages\\Home.js",[],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\pages\\Trending.js",[],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\components\\Log\\index.js",[],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\components\\Log\\LoginForm.js",[],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\components\\Log\\RegisterForm.js",[],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\components\\AppContext.js",[],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\components\\Jikan\\Header.js",["100"],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\components\\jikan\\Header.js",[],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\components\\jikan\\Sidebar.js",["101"],"import React from 'react'\r\n\r\nfunction Sidebar({ topManga }) {\r\n    return (\r\n        \r\n            <aside>\r\n                <nav>\r\n                    <h3>Populaires</h3>\r\n                    {topManga.map(manga => (\r\n\r\n                    <a \r\n                        href='#'\r\n                        key = {manga.mal_id}\r\n                        rel=\"noreferrer\">\r\n                        \r\n                        {manga.title}\r\n                    </a>\r\n\r\n                    ))}\r\n\r\n                </nav>\r\n            </aside>\r\n        \r\n    )\r\n}\r\n\r\nexport default Sidebar\r\n","C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\components\\jikan\\HomeContent.js",[],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\components\\jikan\\MangaCard.js",["102","103"],"import React from 'react'\r\n\r\nfunction MangaCard({manga}) {\r\n    return (\r\n        <article className=\"manga-card\">\r\n            <a href='#' rel=\"noreferrer\">\r\n                <figure>\r\n                    <img\r\n                         src = {manga.image_url} \r\n                         alt = \"manga image\" />\r\n                </figure>\r\n                <h3>{manga.title}</h3>\r\n\r\n            </a>\r\n        </article>\r\n    )\r\n}\r\n\r\nexport default MangaCard\r\n","C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\components\\Navbar.js",["104"],"import React from \"react\";\r\nimport { useContext } from \"react\";\r\nimport { NavLink } from \"react-router-dom\";\r\nimport { UidContext } from \"./AppContext\";\r\nimport Logout from \"./Log/Logout\";\r\nimport { FontAwesomeIcon } from \"@fortawesome/react-fontawesome\";\r\nimport { useSelector } from \"react-redux\";\r\n\r\n// import {\r\n//   faCheckSquare,\r\n//   faCoffee,\r\n//   faSignInAlt,\r\n// } from \"@fortawesome/fontawesome-free-solid\";\r\n\r\nfunction Navbar() {\r\n  const uid = useContext(UidContext);\r\n  const userData = useSelector((state) => state.userReducer);\r\n  // console.log(uid);\r\n\r\n  return (\r\n    <div className=\"nav-container\">\r\n      <div>\r\n        <div className=\"logo\">\r\n          <NavLink exact to=\"/\">\r\n            <img src=\"./img/logo.png\" alt=\"logo\" width=\"100\" />\r\n            <span>Scancheck</span>\r\n          </NavLink>\r\n        </div>\r\n\r\n        <div className=\"icons\">\r\n          <div className=\"icons-bis\">\r\n            <NavLink to=\"/profil\" exact activeClassName=\"active-icon-nav\">\r\n              <span>\r\n                <FontAwesomeIcon icon={\"user-circle\"} /> profil\r\n              </span>\r\n            </NavLink>\r\n            <br />\r\n            <NavLink to=\"/account\" exact activeClassName=\"active-icon-nav\">\r\n              <span>\r\n                <FontAwesomeIcon icon={\"user-cog\"} /> reglages\r\n              </span>\r\n            </NavLink>\r\n            <br />\r\n            <NavLink to=\"/explore\" exact activeClassName=\"active-icon-nav\">\r\n              <span>\r\n                <FontAwesomeIcon icon={\"compass\"} /> explorer\r\n              </span>\r\n            </NavLink>\r\n\r\n            <h5>{\" \" + uid?.user?.username}</h5>\r\n\r\n            <ul>\r\n              <li className=\"welcome\">\r\n                <NavLink exact to=\"/\">\r\n                  <Logout />\r\n                </NavLink>\r\n              </li>\r\n            </ul>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  );\r\n}\r\n\r\nexport default Navbar;\r\n","C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\components\\Log\\Logout.js",[],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\reducers\\index.js",[],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\reducers\\user.reducer.js",[],"C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\actions\\user.actions.js",["105","106"],"import axios from \"axios\";\r\nimport { useEffect, useState } from \"react\";\r\n\r\nexport const GET_USER = \"GET_USER\";\r\nexport const UPDATE_BIO = \"UPDATE_BIO\";\r\nexport const UPDATE_INFO = \"UPDATE_INFO\"\r\n\r\nexport const getUser = () => {\r\n  const token = localStorage.getItem(\"token\");\r\n\r\n  \r\n  return async (dispatch) => {\r\n    await axios({\r\n      method: \"get\",\r\n      url: `${process.env.REACT_APP_API_URL}api/users/me/`,\r\n      withCredentials: false,\r\n      headers: {\r\n        Authorization: `Bearer ${token}`,\r\n      },\r\n    })\r\n      .then((res) => {\r\n        // console.log(res);\r\n        dispatch({ type: GET_USER, payload: res.data });\r\n      })\r\n      .catch((err) => {\r\n        console.log(err);\r\n\r\n      });\r\n  };\r\n};\r\n\r\nexport const updateBio = (id ,bio) => {\r\n  const token = localStorage.getItem('token');\r\n\r\n    return (dispatch) => {\r\n        return axios({\r\n            method: \"put\",\r\n            url:`${process.env.REACT_APP_API_URL}api/users/me/`,\r\n            whithCredentials: false,\r\n            headers: {\r\n                'Authorization': `Bearer ${token}`,\r\n              },  \r\n            data:{bio},\r\n        })\r\n        .then((res)=>{\r\n            // console.log(res)\r\n            dispatch({type: UPDATE_BIO, payload: bio})\r\n        })\r\n        .catch((err)=>console.log(err))\r\n    }\r\n}\r\n\r\nexport const updateInfo = (username,email) => {\r\n    const token = localStorage.getItem('token');\r\n    console.log({username})\r\n\r\n    return(dispatch) => {\r\n        return axios({\r\n            method: \"put\",\r\n            url:`${process.env.REACT_APP_API_URL}api/users/me/`,\r\n            whithCredentials: false,\r\n            headers: {\r\n                'Authorization': `Bearer ${token}`,\r\n              },  \r\n            data :{\r\n                username,\r\n                email\r\n            }\r\n        })\r\n        .then((res)=>{\r\n            console.log(res)\r\n            dispatch({type: UPDATE_INFO, payload:{username,email}})\r\n        })\r\n    }\r\n}\r\n","C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\pages\\Account.js",["107"],"import React from 'react';\r\nimport { Uid } from \"../components/AppContext\";\r\nimport UpdateProfil from \"../components/Setting/UpdateProfil\";\r\nimport Navbar from \"../components/Navbar\"\r\nfunction Account() {\r\n    return (\r\n        <div>\r\n            <Navbar/>\r\n            <UpdateProfil/>\r\n        </div>\r\n    )\r\n}\r\n\r\nexport default Account\r\n","C:\\Users\\landrykf\\Desktop\\PROJETS\\SIMPLON\\Projet-Chef-D-Oeuvre\\frontend\\src\\components\\Setting\\UpdateProfil.js",["108","109","110","111"],{"ruleId":"112","severity":1,"message":"113","line":44,"column":6,"nodeType":"114","endLine":44,"endColumn":8,"suggestions":"115"},{"ruleId":"116","replacedBy":"117"},{"ruleId":"118","replacedBy":"119"},{"ruleId":"120","severity":1,"message":"121","line":1,"column":9,"nodeType":"122","messageId":"123","endLine":1,"endColumn":16},{"ruleId":"124","severity":1,"message":"125","line":11,"column":21,"nodeType":"126","endLine":14,"endColumn":42},{"ruleId":"124","severity":1,"message":"125","line":6,"column":13,"nodeType":"126","endLine":6,"endColumn":42},{"ruleId":"127","severity":1,"message":"128","line":8,"column":21,"nodeType":"126","endLine":10,"endColumn":48},{"ruleId":"120","severity":1,"message":"129","line":17,"column":9,"nodeType":"122","messageId":"123","endLine":17,"endColumn":17},{"ruleId":"120","severity":1,"message":"130","line":2,"column":10,"nodeType":"122","messageId":"123","endLine":2,"endColumn":19},{"ruleId":"120","severity":